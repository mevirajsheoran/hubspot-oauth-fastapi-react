# Environment Configuration Example
# ==================================
#
# Copy this file to .env and fill in your actual values
# Never commit .env files with real credentials to git

# ===========================================
# Backend Configuration
# ===========================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Application Settings
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# Backend Server
BACKEND_HOST=localhost
BACKEND_PORT=8000

# ===========================================
# OAuth2 Credentials - Airtable
# ===========================================
AIRTABLE_CLIENT_ID=your_airtable_client_id_here
AIRTABLE_CLIENT_SECRET=your_airtable_client_secret_here
AIRTABLE_REDIRECT_URI=http://localhost:8000/integrations/airtable/oauth2callback

# ===========================================
# OAuth2 Credentials - Notion
# ===========================================
NOTION_CLIENT_ID=your_notion_client_id_here
NOTION_CLIENT_SECRET=your_notion_client_secret_here
NOTION_REDIRECT_URI=http://localhost:8000/integrations/notion/oauth2callback

# ===========================================
# OAuth2 Credentials - HubSpot
# ===========================================
HUBSPOT_CLIENT_ID=your_hubspot_client_id_here
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret_here
HUBSPOT_REDIRECT_URI=http://localhost:8000/integrations/hubspot/oauth2callback

# ===========================================
# OAuth2 Credentials - Slack (Optional)
# ===========================================
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here
SLACK_REDIRECT_URI=http://localhost:8000/integrations/slack/oauth2callback

# ===========================================
# Frontend Configuration
# ===========================================
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# ===========================================
# Security Settings
# ===========================================
# Generate a strong secret key for production
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ===========================================
# Database (Optional - for future use)
# ===========================================
DATABASE_URL=sqlite:///./app.db
# Or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/pipeline_ai

# ===========================================
# Monitoring & Logging (Optional)
# ===========================================
SENTRY_DSN=
LOGDNA_INGESTION_KEY=

# ===========================================
# Feature Flags
# ===========================================
ENABLE_SLACK_INTEGRATION=false
ENABLE_ADVANCED_LOGGING=true
ENABLE_RATE_LIMITING=false
